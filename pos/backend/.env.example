# Nile POS - Environment Configuration
# Copy this to .env and update values

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nile_pos
DB_USER=pos_user
DB_PASS=your_secure_password_here

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=3600

# Payment Gateways
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
SQUARE_APP_ID=
SQUARE_ACCESS_TOKEN=

# Email (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@nile.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Cloud Storage (for receipts)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=nile-pos-receipts
AWS_REGION=us-east-1

# Monitoring
SENTRY_DSN=
